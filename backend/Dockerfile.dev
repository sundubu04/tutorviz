FROM node:20-alpine

WORKDIR /app

# Install system dependencies and Tectonic
RUN apk add --no-cache \
    curl \
    ca-certificates \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Install Tectonic for LaTeX compilation (match production Dockerfile version)
ARG TECTONIC_VERSION=0.15.0
RUN ARCH="$(uname -m)" \
    && case "$ARCH" in \
         x86_64) TECTONIC_TARGET=x86_64-unknown-linux-musl ;; \
         aarch64) TECTONIC_TARGET=aarch64-unknown-linux-musl ;; \
         *) echo "unsupported arch: $ARCH"; exit 1 ;; \
       esac \
    && wget -O tectonic.tar.gz "https://github.com/tectonic-typesetting/tectonic/releases/download/tectonic@${TECTONIC_VERSION}/tectonic-${TECTONIC_VERSION}-${TECTONIC_TARGET}.tar.gz" \
    && tar -xzf tectonic.tar.gz -C /usr/local/bin \
    && chmod +x /usr/local/bin/tectonic \
    && rm tectonic.tar.gz \
    && tectonic --version

# Copy package files
COPY package*.json ./

# Install dependencies including dev dependencies
RUN npm install

# Copy source code
COPY . .

# Create uploads directory
RUN mkdir -p uploads

# Expose port 5001
EXPOSE 5001

# Use nodemon for hot reloading in development
CMD ["npm", "run", "dev"]
