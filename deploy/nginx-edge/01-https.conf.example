# HTTPS termination at the edge. Copy to 01-https.conf after the first successful certbot run:
#   cp deploy/nginx-edge/01-https.conf.example deploy/nginx-edge/01-https.conf
# Adjust server_name and ssl_certificate paths if your primary cert name differs
# (Let's Encrypt uses the first -d name under live/<name>/).
#
# Then: docker compose -f docker-compose.prod.yml exec nginx-edge nginx -s reload
#
# Optionally add deploy/nginx-edge/01-https.conf to .gitignore on the server if you customize it.

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name tutorviz.org www.tutorviz.org;

    ssl_certificate     /etc/letsencrypt/live/tutorviz.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/tutorviz.org/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    resolver 127.0.0.11 valid=10s ipv6=off;

    location / {
        set $frontend_upstream http://frontend:80;
        proxy_pass $frontend_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Allow long /api requests (e.g. AI) proxied through frontend nginx (default is 60s).
        proxy_connect_timeout 60s;
        proxy_send_timeout 180s;
        proxy_read_timeout 180s;
    }
}
