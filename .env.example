# Copy to `.env` in the repo root for Docker Compose (never commit `.env`).
# docker-compose.dev.yml / docker-compose.yml use defaults for local `supabase start`
# when these are unset. Set them to use hosted Supabase (or other DB) from dev containers.

# DATABASE_URL=
# DIRECT_URL=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SECRET_KEY=
# CORS_ORIGIN=http://localhost:3000
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Optional dev overrides
# BACKEND_PUBLISH_PORT=5001
# FRONTEND_PUBLISH_PORT=3000
# If you change BACKEND_PUBLISH_PORT, point the SPA at the same host port:
# REACT_APP_API_BASE=http://localhost:5001/api

# Production (docker-compose.prod.yml) — see docs/DEPLOY.md
# FRONTEND_HTTP_PORT=80
# REACT_APP_API_BASE=/api
