FROM node:20-alpine

WORKDIR /app

# Install system dependencies for better file watching
RUN apk add --no-cache \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Copy package files
COPY package*.json ./

# Install dependencies including dev dependencies
RUN npm install

# Copy source code
COPY . .

# Expose port 3000
EXPOSE 3000

# Start development server with hot reloading
CMD ["npm", "start"]
